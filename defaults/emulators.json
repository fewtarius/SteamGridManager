{
  "version": 1,
  "_comment": "SGM Emulator Configuration - All emulators and systems defined here",
  
  "emulators": {
    "retroarch": {
      "display_name": "RetroArch",
      "type": "retroarch",
      "flatpak_id": "org.libretro.RetroArch",
      "description": "Multi-platform emulator frontend with libretro cores"
    },
    "dolphin": {
      "display_name": "Dolphin",
      "type": "standalone",
      "flatpak_id": "org.DolphinEmu.dolphin-emu",
      "launch_args": "-b -e \"{rom}\"",
      "description": "GameCube and Wii emulator"
    },
    "pcsx2": {
      "display_name": "PCSX2",
      "type": "standalone",
      "flatpak_id": "net.pcsx2.PCSX2",
      "launch_args": "\"{rom}\" -batch -fullscreen",
      "description": "PlayStation 2 emulator"
    },
    "ppsspp": {
      "display_name": "PPSSPP",
      "type": "standalone",
      "flatpak_id": "org.ppsspp.PPSSPP",
      "launch_args": "\"{rom}\" --fullscreen",
      "description": "PlayStation Portable emulator"
    },
    "cemu": {
      "display_name": "Cemu",
      "type": "standalone",
      "flatpak_id": "info.cemu.Cemu",
      "launch_args": "-f -g \"{rom}\"",
      "description": "Wii U emulator"
    },
    "xemu": {
      "display_name": "Xemu",
      "type": "standalone",
      "flatpak_id": "app.xemu.xemu",
      "launch_args": "-full-screen -dvd_path \"{rom}\"",
      "description": "Original Xbox emulator"
    },
    "rpcs3": {
      "display_name": "RPCS3",
      "type": "standalone",
      "flatpak_id": "net.rpcs3.RPCS3",
      "launch_args": "\"{rom}\"",
      "description": "PlayStation 3 emulator"
    },
    "yuzu": {
      "display_name": "Yuzu",
      "type": "standalone",
      "flatpak_id": "org.yuzu_emu.yuzu",
      "launch_args": "-f \"{rom}\"",
      "description": "Nintendo Switch emulator (deprecated)"
    },
    "citra": {
      "display_name": "Citra",
      "type": "standalone",
      "flatpak_id": "org.citra_emu.citra",
      "launch_args": "\"{rom}\"",
      "description": "Nintendo 3DS emulator"
    },
    "vita3k": {
      "display_name": "Vita3K",
      "type": "native",
      "executable": "Vita3K",
      "launch_args": "-F -r \"{title_id}\"",
      "launch_mode": "title_id",
      "description": "PlayStation Vita emulator (uses title IDs)"
    },
    "mame": {
      "display_name": "MAME",
      "type": "native",
      "executable": "mame",
      "launch_args": "\"{rom_stem}\"",
      "description": "Multiple Arcade Machine Emulator"
    }
  },

